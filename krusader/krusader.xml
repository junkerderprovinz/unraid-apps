<?xml version="1.0"?>
<Container version="2">
  <Name>Krusader</Name>
  <Beta>false</Beta>
  <Repository>junkerderprovinz/krusader:latest</Repository>
  <Registry>https://hub.docker.com/r/junkerderprovinz/krusader</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <ReadMe>https://github.com/junkerderprovinz/krusader/blob/main/README.md</ReadMe>
  <Support>https://forums.unraid.net/topic/198816-support-junkerderprovinz-krusader/</Support>
  <Project>https://krusader.org</Project>
  <Overview>
    Krusader file manager with native Dark Mode (Dark Mode) – built on
    Selkies for a smooth,
    hardware-accelerated web desktop. Far snappier than the noVNC-based
    Krusader containers (binhex / jlesage / ich777).&#xD;
    &#xD;
    What's pre-configured:&#xD;
    • Dark Mode theme for Krusader, Kate and KDE&#xD;
    • Kate as Krusader's external editor&#xD;
    • RAR support: right-click → "Extract RAR here" / "to subfolder"&#xD;
    • 7z, ZIP, TAR, GZ, BZ2, XZ, LHA, ARJ, ACE, RPM, CPIO&#xD;
    • Selectable UI language: 25 languages incl. German, English,&#xD;
      French, Spanish, Italian, Portuguese (PT/BR), Dutch, Catalan, Basque,&#xD;
      Irish, Danish, Swedish, Norwegian, Finnish, Icelandic, Polish, Czech,&#xD;
      Slovak, Hungarian, Romanian, Slovenian, Croatian, Serbian, Bulgarian,&#xD;
      Ukrainian, Russian, Greek, Turkish, Hebrew, Arabic, Japanese, Korean,&#xD;
      Chinese (CN/TW)&#xD;
    • Spell-checking in Kate for ~25 languages via Hunspell&#xD;
    &#xD;
    Notes:&#xD;
    • The /storage volume defaults to /mnt – this gives Krusader access to all&#xD;
      shares (/mnt/user) and individual disks (/mnt/disk*).&#xD;
    • WebUI opens via HTTPS on port 3001 (self-signed cert — accept it once).&#xD;
      HTTPS is required for clipboard support in the browser. HTTP 3000 is&#xD;
      also exposed as a fallback.&#xD;
    • PUID/PGID default to 99/100 (nobody/users on Unraid).&#xD;
    • Auth: leave "WebUI Username" and "Password" EMPTY to run without&#xD;
      login. Set both to enable HTTP-basic auth on the WebUI. Recommended&#xD;
      whenever the container is reachable from anything beyond your LAN.&#xD;
    &#xD;
    Source on GitHub: https://github.com/junkerderprovinz/krusader&#xD;
  </Overview>
  <Category>Tools: Productivity:</Category>
  <WebUI>https://[IP]:[PORT:3001]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/junkerderprovinz/unraid-apps/main/krusader/krusader.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/junkerderprovinz/unraid-apps/main/krusader/icon.png</Icon>
  <ExtraParams>--restart=unless-stopped --shm-size=1gb</ExtraParams>

  <!-- ========================================================
       PORTS
       ======================================================== -->
  <Config Name="WebUI Port (HTTPS / Selkies)" Target="3001" Default="3001" Mode="tcp"
          Description="HTTPS port of the Selkies WebUI (self-signed cert). This is the default WebUI — HTTPS is required for clipboard support in the browser. Accept the self-signed certificate once."
          Type="Port" Display="always" Required="true" Mask="false">3001</Config>

  <Config Name="WebUI Port (HTTP / Selkies)" Target="3000" Default="3000" Mode="tcp"
          Description="HTTP port of the Selkies WebUI. Optional fallback — the WebUI defaults to HTTPS (3001) because browsers only allow seamless clipboard over HTTPS."
          Type="Port" Display="always" Required="false" Mask="false">3000</Config>

  <!-- ========================================================
       PATHS
       ======================================================== -->
  <Config Name="AppData (/config)" Target="/config" Default="/mnt/user/appdata/krusader" Mode="rw"
          Description="Persistent Krusader configs, history, bookmarks, default-files lock."
          Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/krusader</Config>

  <Config Name="Storage (/storage)" Target="/storage" Default="/mnt" Mode="rw,slave"
          Description="Main path for file operations. Default /mnt gives access to all shares (/mnt/user) and individual disks (/mnt/disk*). Adjust if you only need specific shares."
          Type="Path" Display="always" Required="true" Mask="false">/mnt</Config>

  <!-- ========================================================
       UI PREFERENCES (with Unraid dropdowns via | syntax)
       ========================================================
       Unraid renders <Default>a|b|c</Default> as a select-dropdown when
       the value has at least one '|' separator. The first value before the
       first '|' is the pre-selected default.
  -->
  <Config Name="UI Language (KRUSADER_LANG)" Target="KRUSADER_LANG"
          Default="de|en|fr|es|it|pt|nl|ca|eu|ga|da|sv|nb|fi|is|pl|cs|sk|hu|ro|sl|hr|sr|bg|uk|ru|el|tr|he|ar|ja|ko|zh|system" Mode=""
          Description="Language for the Krusader / Kate UI. 25 codes available: de, en, fr, es, it, pt, nl, ca, eu, ga, da, sv, nb, fi, is, pl, cs, sk, hu, ro, sl, hr, sr, bg, uk, ru, el, tr, he, ar, ja, ko, zh. Use 'system' for the container default. Re-applied on every container start."
          Type="Variable" Display="always" Required="false" Mask="false">de</Config>

  <Config Name="Theme (KRUSADER_THEME)" Target="KRUSADER_THEME"
          Default="dark|light" Mode=""
          Description="Color scheme. 'dark' = Dark Mode, 'light' = Breeze."
          Type="Variable" Display="always" Required="false" Mask="false">dark</Config>

  <!-- ========================================================
       KASMVNC SECURITY
       ======================================================== -->
  <Config Name="WebUI Username" Target="CUSTOM_USER" Default="" Mode=""
          Description="Optional. Username for HTTP-basic-auth on the WebUI. Leave EMPTY together with the password for no login. Set both fields to enable login (recommended outside trusted LANs)."
          Type="Variable" Display="always" Required="false" Mask="false"/>

  <Config Name="WebUI Password" Target="PASSWORD" Default="" Mode=""
          Description="Optional. Password for HTTP-basic-auth on the WebUI. Leave EMPTY together with the username for no login. STRONGLY recommended whenever the container is reachable from outside your LAN."
          Type="Variable" Display="always" Required="false" Mask="true"/>

